# ============================================================
# ETABS LLM Automation — Environment Variables
# Copy this file to .env and fill in values as needed.
# ============================================================

# --- Ollama (LLM) ---
OLLAMA_URL=http://ollama:11434          # Docker service name; use localhost:11434 outside Docker
OLLAMA_MODEL=llama3.1:8b                # Any Ollama model tag you've pulled

# --- ETABS Python microservice ---
# Runs on the Windows host (not in Docker), so backend reaches it via host IP.
ETABS_SERVICE_URL=http://host.docker.internal:5000

# --- Backend ---
BACKEND_PORT=3000

# --- Frontend (Vite injects these at build time) ---
VITE_API_URL=http://localhost:3000/api
